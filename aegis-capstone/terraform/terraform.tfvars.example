# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# --- required ---
azure_subscription_id = "00000000-0000-0000-0000-000000000000"
operator_ip           = "203.0.113.42/32"   # your workstation public IP — get via: curl ifconfig.me

# --- optional overrides ---
# azure_locations     = ["australiaeast", "australiasoutheast", "southeastasia"]  # 3 regions for r1/r2/r3
# azure_vm_size       = "Standard_D2s_v5"
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
# vm_admin_user       = "ansible_user"

# Note: VMs use a custom Packer-baked image from Azure Compute Gallery
# (aegis_gallery / aegis-ubuntu-base). The image must exist BEFORE
# terraform apply — see docs/runbooks/deploy.md for Packer build steps.
